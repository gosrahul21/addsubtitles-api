datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum SubscriptionTier {
  FREE
  PRO
  ENTERPRISE
}

enum ProjectStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model User {
  id                String           @id @default(uuid())
  email             String           @unique
  passwordHash      String?          @map("password_hash") // Nullable for Google OAuth users
  googleId          String?          @unique @map("google_id")
  refreshTokenHash  String?          @map("refresh_token_hash") // Encrypted refresh token for rotation
  subscriptionTier  SubscriptionTier @default(FREE) @map("subscription_tier")
  createdAt         DateTime         @default(now()) @map("created_at")
  projects          Project[]
  presets           Preset[]

  @@map("users")
}

model Project {
  id           String        @id @default(uuid())
  userId       String?       @map("user_id") // Optional to support anonymous guest creations
  sessionId    String?       @map("session_id") // Used to track and claim guest projects on login
  status       ProjectStatus @default(PENDING)
  videoUrl     String?       @map("video_url")
  settingsJson Json          @default("{}") @map("settings_json")
  createdAt    DateTime      @default(now()) @map("created_at")
  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subtitles    Subtitle[]
  exports      Export[]

  @@map("projects")
}

model Subtitle {
  id             String   @id @default(uuid())
  projectId      String   @map("project_id")
  language       String   @default("en")
  timestampStart Float    @map("timestamp_start") // in seconds
  timestampEnd   Float    @map("timestamp_end")   // in seconds
  text           String
  wordsJson      Json?    @map("words_json")      // Store raw per-word timings [{ word, start, end }]
  speaker        String?                           // Speaker label (e.g. "A", "B")
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("subtitles")
}

model Preset {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  styleJson Json     @map("style_json")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("presets")
}

model Export {
  id         String        @id @default(uuid())
  projectId  String        @map("project_id")
  status     ProjectStatus @default(PENDING)
  downloadUrl String?      @map("download_url")
  createdAt  DateTime      @default(now()) @map("created_at")
  project    Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("exports")
}
