datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum ProjectStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model User {
  id                String           @id @default(uuid())
  email             String           @unique
  passwordHash      String?          @map("password_hash") // Nullable for Google OAuth users
  googleId          String?          @unique @map("google_id")
  refreshTokenHash  String?          @map("refresh_token_hash") // Encrypted refresh token for rotation
  subscriptionTier  String           @default("FREE") @map("subscription_tier")
  createdAt         DateTime         @default(now()) @map("created_at")
  projects          Project[]
  presets           Preset[]
  subscription      Subscription?
  orders            Order[]

  @@map("users")
}

model SubscriptionPlan {
  id           String         @id @default(uuid())
  name         String         // e.g., "PRO", "ENTERPRISE"
  price        Float          // e.g., 19.00
  daysCovered  Int            @map("days_covered") // e.g., 30
  createdAt    DateTime       @default(now()) @map("created_at")
  subscriptions Subscription[]
  orders       Order[]

  @@map("subscription_plans")
}

model Subscription {
  userId             String           @id @map("user_id")
  subscriptionId     String           @default(uuid()) @map("subscription_id")
  subscriptionPlanId String           @map("subscription_plan_id")
  startDate          DateTime         @default(now()) @map("start_date")
  endDate            DateTime         @map("end_date")
  status             String           // "active", "expired", "cancelled"
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan               SubscriptionPlan @relation(fields: [subscriptionPlanId], references: [id])

  @@map("subscriptions")
}

model Order {
  id                 String           @id @default(uuid())
  userId             String           @map("user_id")
  subscriptionPlanId String           @map("subscription_plan_id")
  amount             Float
  currency           String           @default("USD")
  status             String           // "completed", "failed", "pending"
  paymentGateway     String           @default("DODO_PAYMENTS") @map("payment_gateway")
  gatewayOrderId     String?          @map("gateway_order_id")
  createdAt          DateTime         @default(now()) @map("created_at")
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan               SubscriptionPlan @relation(fields: [subscriptionPlanId], references: [id])

  @@map("orders")
}

model Project {
  id           String        @id @default(uuid())
  userId       String?       @map("user_id") // Optional to support anonymous guest creations
  sessionId    String?       @map("session_id") // Used to track and claim guest projects on login
  status       ProjectStatus @default(PENDING)
  videoUrl     String?       @map("video_url")
  settingsJson Json          @default("{}") @map("settings_json")
  createdAt    DateTime      @default(now()) @map("created_at")
  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subtitles    Subtitle[]
  exports      Export[]

  @@map("projects")
}

model Subtitle {
  id             String   @id @default(uuid())
  projectId      String   @map("project_id")
  language       String   @default("en")
  timestampStart Float    @map("timestamp_start") // in seconds
  timestampEnd   Float    @map("timestamp_end")   // in seconds
  text           String
  wordsJson      Json?    @map("words_json")      // Store raw per-word timings [{ word, start, end }]
  speaker        String?                           // Speaker label (e.g. "A", "B")
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("subtitles")
}

model Preset {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  styleJson Json     @map("style_json")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("presets")
}

model Export {
  id         String        @id @default(uuid())
  projectId  String        @map("project_id")
  status     ProjectStatus @default(PENDING)
  downloadUrl String?      @map("download_url")
  createdAt  DateTime      @default(now()) @map("created_at")
  project    Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("exports")
}
